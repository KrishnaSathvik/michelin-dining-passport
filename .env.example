# Public Supabase (safe for the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret key — never prefix with NEXT_PUBLIC_
SUPABASE_SECRET_KEY=

# Site origin used for auth redirects and metadata
# Local: http://localhost:3000
# Production: https://your-domain.example
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set true only after Google OAuth is configured in the Supabase dashboard
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Optional analytics / monitoring (disabled unless explicitly enabled)
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_MONITORING_ENABLED=false
# Provider-specific keys — leave blank until a vendor is chosen
# NEXT_PUBLIC_ANALYTICS_WRITE_KEY=
# NEXT_PUBLIC_SENTRY_DSN=

# Map tiles (defaults to public demo/OSM-compatible sources in app code)
# NEXT_PUBLIC_MAP_STYLE_URL=

# Email delivery is configured in the Supabase dashboard (SMTP / auth templates),
# not via app env vars in the launch configuration.

# Data-update CLI safety — never set these in the Next.js runtime
# MDP_ALLOW_PRODUCTION_DATA_APPLY=false
