# Public Supabase (safe for the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secret key — never prefix with NEXT_PUBLIC_
SUPABASE_SECRET_KEY=

# Site origin used for auth redirects and metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set true only after Google OAuth is configured in the Supabase dashboard
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Google Places UI Kit (browser) — keep disabled until keys + budgets are ready
# See docs/google-places/google-cloud-setup.md
NEXT_PUBLIC_GOOGLE_PLACES_UI_KIT_ENABLED=false
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# Server/CLI Place ID matching only — never expose via NEXT_PUBLIC_*
GOOGLE_PLACES_MATCHING_API_KEY=
